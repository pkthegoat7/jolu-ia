# ─── App ────────────────────────────────────────────────────────────────────
# URL base da aplicação (Vercel preenche automaticamente em produção)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Banco de dados (Supabase / PostgreSQL) ──────────────────────────────────
# Obtenha em: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres"

# ─── Supabase Storage ────────────────────────────────────────────────────────
# Obtenha em: Supabase Dashboard → Project Settings → API
# IMPORTANTE: Use a Service Role Key somente no servidor — nunca exponha no cliente
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_KEY=sua_service_role_key

# ─── Autenticação JWT ────────────────────────────────────────────────────────
# Gere uma string aleatória forte (ex: openssl rand -base64 32)
# OBRIGATÓRIO em produção
JWT_SECRET=sua_chave_secreta_forte

# Secret separado para tokens de análise de lead (diferente do JWT_SECRET)
# Se não definido, usa JWT_SECRET como fallback (não recomendado)
ANALYSIS_TOKEN_SECRET=outro_secret_aleatorio_forte

# ─── Google Gemini AI ────────────────────────────────────────────────────────
# Obtenha em: aistudio.google.com → API Keys
GEMINI_API_KEY=sua_chave_gemini

# ─── OpenAI (embeddings p/ recomendação de produtos via pgvector) ────────────
# Modelo usado: text-embedding-3-small (1536 dim). Sem essa chave, o sistema
# cai no fallback hardcoded de produtos.
OPENAI_API_KEY=sk-...

# ─── Pgvector (Postgres read-only externo com produtos do e-commerce) ────────
# Banco separado do DATABASE_URL principal. Usuário read-only, somente a tabela
# de produtos. Sem essas vars, cai no fallback hardcoded.
# Solicite as credenciais ao admin (NÃO commitar a senha).
#
# Use UMA das duas formas:
#
# (A) Connection string única — recomendada:
PGVECTOR_URL=postgresql://USER:SENHA@HOST:PORT/postgres
#
# (B) Campos separados — alternativa equivalente. Se PGVECTOR_URL estiver
#     definida, ela vence; senão usa estes 5 campos.
# PGVECTOR_HOST=
# PGVECTOR_PORT=
# PGVECTOR_DB=
# PGVECTOR_USER=
# PGVECTOR_PASSWORD=
#
# Tabela (opcional). Default: n8n_vectors_produtos_ecommerce
# PGVECTOR_TABLE=n8n_vectors_produtos_ecommerce

# ─── Email (Gmail SMTP) ──────────────────────────────────────────────────────
# GMAIL_USER: endereço Gmail que envia os emails (ex: contato@gmail.com)
# GMAIL_APP_PASSWORD: senha de app gerada em myaccount.google.com/apppasswords
GMAIL_USER=seu@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ─── Registro de admin ───────────────────────────────────────────────────────
# Defina como "true" para habilitar o endpoint POST /api/auth/register
# Deixe vazio ou remova para bloquear registro em todos os ambientes (recomendado em produção)
ALLOW_REGISTRATION=

# ─── WooCommerce (opcional) ──────────────────────────────────────────────────
# Sincroniza leads como clientes no WooCommerce após a análise
# Gere as chaves em: WooCommerce → Configurações → Avançado → REST API
WC_URL=https://seusite.com
WC_CONSUMER_KEY=ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WC_CONSUMER_SECRET=cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Webhook (opcional) ──────────────────────────────────────────────────────
# Chave para assinar os payloads enviados (header X-Jolu-Signature: sha256=...)
# Deixe vazio para desativar a assinatura
WEBHOOK_SECRET=