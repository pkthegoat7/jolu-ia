# ─── App ────────────────────────────────────────────────────────────────────
# URL base da aplicação (Vercel preenche automaticamente em produção)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Banco de dados (Supabase / PostgreSQL) ──────────────────────────────────
# Obtenha em: Supabase Dashboard → Project Settings → Database → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/postgres"

# ─── Supabase Storage ────────────────────────────────────────────────────────
# Obtenha em: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_KEY=sua_service_role_key

# ─── Autenticação JWT ────────────────────────────────────────────────────────
# Gere uma string aleatória forte (ex: openssl rand -base64 32)
JWT_SECRET=sua_chave_secreta_forte

# ─── Anthropic (Claude AI) ───────────────────────────────────────────────────
# Obtenha em: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Obtenha em: resend.com → API Keys
# Sem domínio próprio: use onboarding@resend.dev como remetente (free tier)
RESEND_API_KEY=re_...

# ─── Webhook (opcional) ──────────────────────────────────────────────────────
# Chave para assinar os payloads enviados (header X-Jolu-Signature: sha256=...)
# Deixe vazio para desativar a assinatura
WEBHOOK_SECRET=
